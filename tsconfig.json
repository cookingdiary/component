{
  // "$schema": "https://json.schemastore.org/tsconfig", // Removed or commented out to avoid schema loading error
  "compilerOptions": {
    "module": "esnext",
    "declaration": true,
    "noImplicitAny": true,
    "removeComments": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "jsx": "preserve",
    "noLib": false,
    "target": "es6",
    "lib": [
      "esnext",
      "dom"
    ],
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true                        
  },
  "exclude": [
    "node_modules",
    "dist/**",
    "**/__tests__"    
  ]
}
